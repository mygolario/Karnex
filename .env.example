# ================================
# Karnex Environment Variables
# ================================
# Copy to .env.local for local development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Database (Supabase Postgres pooler) ---
# Replace placeholders with values from Supabase Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres.[ref]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.[ref]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# --- App URLs ---
NEXT_PUBLIC_APP_URL=https://www.karnex.ir
NEXT_PUBLIC_SITE_URL=https://www.karnex.ir

# --- Google OAuth (used by Supabase Auth; set in Supabase via `supabase config push`) ---
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# --- OpenRouter AI ---
OPENROUTER_API_KEY=your_openrouter_api_key
# Web search plugin engine: auto | exa | parallel (enable Web Search in OpenRouter dashboard)
OPENROUTER_WEB_SEARCH_ENGINE=auto

# --- Grounded research / Persian KB RAG ---
SERPER_API_KEY=
FIRECRAWL_API_KEY=
HUGGINGFACE_API_TOKEN=

# --- Iranian map (Neshan) ---
NESHAN_API_KEY=

# --- Payment (Zibal) ---
ZIBAL_MERCHANT=your_real_zibal_merchant_id
ZIBAL_WEBHOOK_SECRET=
ZIBAL_ALLOWED_IPS=

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key

# --- Storage (Supabase or S3-compatible) ---
STORAGE_ENDPOINT=
STORAGE_BUCKET_NAME=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=

# --- Admin ---
ADMIN_EMAILS=your_admin@email.com
ADMIN_CC_EMAIL=your_cc@email.com

# --- Optional ---
REDIS_URL=
NEXT_PUBLIC_GA_ID=G-4H64BXL3ML
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=ario-tq
SENTRY_PROJECT=karnex
SENTRY_AUTH_TOKEN=
