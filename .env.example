# Karnex environment variables
# Copy to `.env` / `.env.local` and fill in values.
# Core (required for signup/login/dashboard):

DATABASE_URL=
DIRECT_URL=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=https://www.karnex.ir
NEXT_PUBLIC_APP_URL=https://www.karnex.ir

# Payments (Zibal). Without ZIBAL_MERCHANT, mock gateway is used.
# Use merchant code `zibal` for public sandbox; real merchant for production.
ZIBAL_MERCHANT=
# Fixie static IP proxy (required in prod if Zibal whitelist needs it)
FIXIE_URL=

# AI
OPENROUTER_API_KEY=
OPENROUTER_WEB_SEARCH_ENGINE=auto
HUGGINGFACE_API_TOKEN=
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# Email (Resend)
RESEND_API_KEY=

# Storage (Liara S3-compatible or STORAGE_*)
LIARA_ENDPOINT=
LIARA_ACCESS_KEY=
LIARA_SECRET_KEY=
LIARA_BUCKET=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_ID=

# Rate limiting
# Edge middleware: Upstash REST (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Node API routes (ioredis TCP) — optional alternative
REDIS_URL=

# Admin allowlist (comma-separated emails) — also set Prisma user.role = admin
ADMIN_EMAILS=

# Google OAuth (optional — configure in Supabase dashboard too)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
